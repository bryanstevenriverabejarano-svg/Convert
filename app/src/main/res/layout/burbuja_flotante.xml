<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/burbujaLayout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/background_light"
    android:elevation="10dp"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Botones en fila -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/icono_mic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Micrófono"
            android:padding="6dp"
            android:src="@drawable/baseline_mic_24" />

        <ImageView
            android:id="@+id/icono_voz"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voz"
            android:padding="6dp"
            android:src="@drawable/baseline_voice_chat_24" />
    </LinearLayout>

    <!-- Texto de respuesta -->
    <TextView
        android:id="@+id/textoRespuesta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="..."
        android:textColor="#000000"
        android:textSize="14sp"
        android:visibility="gone" />

</LinearLayout>